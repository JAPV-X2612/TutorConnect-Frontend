# Clerk — Publishable Key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Backend URL — ngrok tunnel URL for local dev with a physical device
EXPO_PUBLIC_API_URL=https://<your-ngrok-subdomain>.ngrok-free.app/api

# Dev-only flag — set to "true" to skip all backend calls and run UI in isolation
# Leave empty or omit in production
EXPO_PUBLIC_FRONTEND_ONLY=
